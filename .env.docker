# Jarvis AI Agent - Docker 环境变量配置
# 复制此文件为 .env 后修改配置（docker-compose 会自动读取 .env 文件）

# 安全密钥（用于 JWT 签名和 API Key 加密，请务必修改为随机字符串）
SECRET_KEY=change-this-to-a-random-secret-key

# 默认 LLM Provider
# 可选: llama_cpp / deepseek / openai / moonshot / zhipu / dashscope / siliconflow / custom
DEFAULT_PROVIDER=llama_cpp

# 默认 Agent 模式（plan_execute / react / chat）
DEFAULT_AGENT_MODE=plan_execute

# 本地 llama.cpp 服务地址（仅 DEFAULT_PROVIDER=llama_cpp 时生效）
# Docker 中访问宿主机服务请使用 host.docker.internal
LLAMACPP_BASE_URL=http://host.docker.internal:8081
