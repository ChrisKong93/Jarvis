# ============================================================
# Jarvis - Docker 中国大陆加速配置
# 使用方式：复制此文件为 .env 后修改配置
#   cp .env.docker.china .env
# ============================================================

# pip 镜像源加速（清华源）
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# 安全密钥（务必修改为随机字符串）
SECRET_KEY=change-this-to-a-random-secret-key

# 默认 LLM Provider
DEFAULT_PROVIDER=llama_cpp

# 默认 Agent 模式
DEFAULT_AGENT_MODE=plan_execute

# 本地 llama.cpp 服务地址（Docker 中通过 host.docker.internal 访问宿主机）
LLAMACPP_BASE_URL=http://host.docker.internal:8081
