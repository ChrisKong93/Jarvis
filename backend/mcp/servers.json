{
  "description": "Jarvis MCP 服务器配置文件。在此添加你的 MCP 服务器。",
  "servers": [
    {
      "name": "web-fetch",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@fnnm/fetch"
      ],
      "env": {}
    },
    {
      "name": "playwright",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@executeautomation/playwright-mcp-server"
      ],
      "env": {}
    }
  ]
}