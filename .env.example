# Jarvis 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# 默认使用的 Provider（llama_cpp / deepseek / openai / moonshot / zhipu / dashscope / siliconflow / custom）
DEFAULT_PROVIDER=llama_cpp

# 本地 llama.cpp 服务地址
LLAMA_CPP_URL=http://192.168.0.201:8081

# --- 云端模型 API Key（按需配置）---

# DeepSeek: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# OpenAI: https://platform.openai.com/
OPENAI_API_KEY=

# Moonshot (Kimi): https://platform.moonshot.cn/
MOONSHOT_API_KEY=

# 智谱 GLM: https://open.bigmodel.cn/
ZHIPU_API_KEY=

# 通义千问: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=

# SiliconFlow: https://siliconflow.cn/
SILICONFLOW_API_KEY=

# 自定义 OpenAI 兼容 API
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=
