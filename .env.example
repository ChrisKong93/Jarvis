# ============================================================
# Jarvis AI Agent - 环境变量配置
# 复制此文件为 .env 后修改配置：
#   cp .env.example .env
#
# 中国大陆用户如需使用 pip 镜像加速，可取消下方 PIP_INDEX_URL 注释
# ============================================================

# ---- 安全密钥（务必修改为随机字符串，用于 JWT 签名和 API Key 加密） ----
SECRET_KEY=your-secret-key-change-this-to-a-random-string

# ---- 默认 LLM Provider ----
# 可选: llama_cpp / deepseek / openai / moonshot / zhipu / dashscope / siliconflow / custom
DEFAULT_PROVIDER=llama_cpp

# ---- 默认 Agent 模式 ----
# 可选: plan_execute / react / chat
DEFAULT_AGENT_MODE=plan_execute

# ---- LLM 服务地址 ----
# 本地开发: 填入 llm 服务所在主机 IP
# Docker 部署: 使用 host.docker.internal 访问宿主机服务
LLAMACPP_BASE_URL=http://192.168.0.201:8081
# LLAMACPP_BASE_URL=http://host.docker.internal:8081    # Docker 环境

# ---- 服务端口 ----
# 后端 HTTP 服务监听端口（默认 8000）
# PORT=8000

# ---- Embedding 模型 ----
# 用于记忆系统的文本向量化模型（默认 all-MiniLM-L6-v2）
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---- MCP 配置 ----
# MCP（Model Context Protocol）服务器配置文件路径
# MCP_CONFIG_PATH=backend/mcp/servers.json
# MCP 服务器连接超时（秒，默认 60）
# MCP_CONNECT_TIMEOUT=60

# ---- Embedding 模型缓存目录 ----
# HuggingFace 模型下载缓存路径（Docker 部署时默认已配置）
# HF_HOME=/app/backend/memory/embeddings_cache

# ---- pip 镜像源加速（中国大陆用户） ----
# Docker 构建时可启用清华源加速
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
