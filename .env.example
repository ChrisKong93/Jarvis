# Jarvis AI Agent - 环境变量配置
# 复制此文件为 .env 后修改配置

# 安全密钥（用于 JWT 签名和 API Key 加密，请务必修改为随机字符串）
SECRET_KEY=your-secret-key-change-this-to-a-random-string

# 默认 LLM Provider（llama_cpp / deepseek / openai / moonshot / zhipu / dashscope / siliconflow / custom）
DEFAULT_PROVIDER=llama_cpp

# 默认 Agent 模式（react / graph）
DEFAULT_AGENT_MODE=graph

# 本地 llama.cpp 服务地址（仅 DEFAULT_PROVIDER=llama_cpp 时生效）
LLAMACPP_BASE_URL=http://192.168.0.201:8081
